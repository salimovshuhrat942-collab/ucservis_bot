# ==== Bot ====
BOT_TOKEN=123456:AAA-your-telegram-bot-token
BOT_USERNAME=your_bot_username

# ==== Owner / Admins ====
OWNER_ID=123456789
ADMIN_IDS=123456789,987654321

# ==== Database ====
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# PostgreSQL (production, uncomment to switch):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ==== Admin Panel ====
ADMIN_PANEL_SECRET=change-this-to-a-long-random-string
ADMIN_PANEL_PASSWORD=change-this-password
ADMIN_PANEL_PORT=8000

# ==== Storage ====
TEMP_DIR=./storage/temp
MAX_UPLOAD_MB=200
MAX_UPLOAD_MB_PREMIUM=2000
MAX_DURATION_SEC=600

# ==== Queue ====
QUEUE_WORKERS=2
QUEUE_WORKERS_PREMIUM=2

# ==== Referral ====
REFERRAL_REWARD_CONVERSIONS=1

# ==== FFmpeg ====
FFMPEG_PRESET=veryfast
FFMPEG_THREADS=2

# ==== Misc ====
DEFAULT_LANGUAGE=uz
